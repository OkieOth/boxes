}
ConnectionNode --> "0..*" ConnectionEdge


note top of ConnectionNode
helper type for calculating the
connections between elements
end note
    
class ConnectionEdge {
    +**x** Integer
    +**y** Integer
    +destNodeId? String
    +**weight** Integer
}


note top of ConnectionEdge
edge type to store edges
on a connection node
end note
    
class CommentContainer {
    +**text** String
    +**label** String
    +**format** CommentFormat
    +**markerX** Integer
    +**markerY** Integer
    +**markerTextWidth** Integer
    +**markerTextHeight** Integer
    +**textWidth** Integer
    +**textHeight** Integer
