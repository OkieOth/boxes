    +formats? OverlayFormatDef
}
DocOverlay --> "0..*" OverlayEntry
DocOverlay o-- OverlayRadiusDef
DocOverlay o-- OverlayFormatDef


note top of DocOverlay
Definition of a topic related
overlay ... for instance for
heatmaps
end note
    
class OverlayEntry {
    +**value** Double
    +**radius** Double
    +**x** Integer
    +**y** Integer
    +**format** BoxFormat
}
OverlayEntry o-- BoxFormat


class BoxesDocument {
    +**title** String
