@startuml BoxesDocument

hide empty methods
skinparam noteBackgroundColor #EAEAEA
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor Black
}




class Comment {
    +**text** String
    +label? String
    +format? String
    +step? Integer
}


note top of Comment
Object to define comments in
the diagrams
end note
    
class ConnRestriction {
    +source? ConnRestrItem
    +dest? ConnRestrItem
}
ConnRestriction o-- ConnRestrItem


note top of ConnRestriction
container to define closer how
a connection should be routed
end note
    
class ConnRestrItem {
    +**noTop** Boolean
    +**noBottom** Boolean
    +**noLeft** Boolean
    +**noRight** Boolean
}


note top of ConnRestrItem
possible options to restrict a
connection start or end
end note
    
class LayoutElement {
    +**id** String
    +**caption** String
    +**text1** String
    +**text2** String
    +comments? List<Comment>
    +**hiddenComments** Boolean
    +image? ImageContainer
    +vertical? LayoutElemContainer
    +horizontal? LayoutElemContainer
    +**x** Integer
    +**y** Integer
    +**width** Integer
    +**height** Integer
    +**centerX** Integer
    +**centerY** Integer
    +format? BoxFormat
    +connections? List<LayoutElemConnection>
    +leftYToStart? Integer
    +rightYToStart? Integer
    +topXToStart? Integer
    +bottomXToStart? Integer
    +xTextBox? Integer
    +yTextBox? Integer
    +widthTextBox? Integer
    +heightTextBox? Integer
    +dontBlockConPaths? Boolean
    +tags? List<String>
    +dataLink? String
    +connRestrictions? ConnRestrItem
}
LayoutElement --> "0..*" Comment
LayoutElement o-- ImageContainer
LayoutElement o-- LayoutElemContainer
LayoutElement o-- BoxFormat
LayoutElement --> "0..*" LayoutElemConnection
LayoutElement o-- ConnRestrItem


class LayoutElemContainer {
    +**x** Integer
    +**y** Integer
    +**width** Integer
    +**height** Integer
    +**elems** List<LayoutElement>
}
LayoutElemContainer --> "0..*" LayoutElement


enum Type {
    normal,
    italic,
}


enum Weight {
    normal,
    bold,
}


enum Aligned {
    left,
    center,
    right,
}


enum Anchor {
    middle,
    left,
    right,
}


class FontDef {
    +**size** Integer
    +**font** String
    +type? Type
    +weight? Weight
    +**lineHeight** Double
    +**color** String
    +aligned? Aligned
    +**spaceTop** Integer
    +**spaceBottom** Integer
    +**maxLenBeforeBreak** Integer
    +**anchor** Anchor
}
FontDef o-- Type
FontDef o-- Weight
FontDef o-- Aligned
FontDef o-- Anchor


note top of FontDef
Defines the font a text
end note
    
enum Style {
    solid,
    dotted,
    dashed,
}


class LineDef {
    +width? Double
    +style? Style
    +color? String
    +opacity? Double
}
LineDef o-- Style


note top of LineDef
Defines how the border of
the box looks like
end note
    
class FillDef {
    +color? String
    +opacity? Double
}


note top of FillDef
Defines the fill of the
box
end note
    
class ImageDef {
    +description? String
    +**width** Integer
    +**height** Integer
    +base64? String
    +marginTopBottom? Integer
    +marginLeftRight? Integer
    +base64Src? String
}


note top of ImageDef
parameters of an image to
be displayed in the SVG
end note
    
class LayoutElemConnection {
    +**destId** String
    +comment? Comment
    +**sourceArrow** Boolean
    +**destArrow** Boolean
    +format? LineDef
    +**hiddenComments** Boolean
    +connRestrictions? ConnRestriction
    +**tags** List<String>
    +step? Integer
}
LayoutElemConnection o-- Comment
LayoutElemConnection o-- LineDef
LayoutElemConnection o-- ConnRestriction


class ConnectionElem {
    +from? String
    +to? String
    +sourceArrow? Boolean
    +destArrow? Boolean
    +format? LineDef
    +**hiddenComments** Boolean
    +**parts** List<ConnectionLine>
    +**connectionIndex** Integer
    +connRestrictions? ConnRestriction
    +comment? Comment
    +step? Integer
}
ConnectionElem o-- LineDef
ConnectionElem --> "0..*" ConnectionLine
ConnectionElem o-- ConnRestriction
ConnectionElem o-- Comment


class ConnectionLine {
    +**startX** Integer
    +**startY** Integer
    +**endX** Integer
    +**endY** Integer
    +srcLayoutId? String
    +destLayoutId? String
    +**connectionIndex** Integer
    +**lineIndex** Integer
    +format? LineDef
    +**isStart** Boolean
    +**isEnd** Boolean
    +**inverseDirection** Boolean
    +step? Integer
}
ConnectionLine o-- LineDef


class ImageContainer {
    +**x** Integer
    +**y** Integer
    +**width** Integer
    +**height** Integer
    +**marginTopBottom** Integer
    +**marginLeftRight** Integer
    +**imgId** String
}


class BoxFormat {
    +**padding** Integer
